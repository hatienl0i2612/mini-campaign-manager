{
  "name": "@mini-campaign-manager/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npx nx run-many --target=dev --projects=@mini-campaign-manager/backend,@mini-campaign-manager/frontend",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npx nx run-many --target=build --all",
    "build:backend": "npm run build -w packages/backend",
    "build:frontend": "npm run build -w packages/frontend",
    "start:backend": "npm run start -w packages/backend",
    "preview:frontend": "npm run preview -w packages/frontend",
    "test": "npm run test -w packages/backend",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "db:migrate:down": "npm run db:migrate:down -w packages/backend",
    "db:seed": "npm run db:seed -w packages/backend"
  },
  "private": true,
  "dependencies": {},
  "devDependencies": {
    "@nx/js": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "nx": "22.6.5",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "packages/*"
  ]
}
