{
    "name": "@mini-campaign-manager/backend",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n server,lint -c cyan,yellow \"tsx watch --clear-screen=false --tsconfig tsconfig.json -r tsconfig-paths/register src/index.ts\" \"tsc --noEmit --watch --preserveWatchOutput\"",
        "build": "rm -rf dist tsconfig.tsbuildinfo && tsc && tsc-alias --resolve-full-paths",
        "start": "node --import tsx/esm dist/index.js",
        "db:migrate": "tsx -r tsconfig-paths/register src/db/migrate.ts",
        "db:migrate:down": "tsx -r tsconfig-paths/register src/db/migrate.ts --down",
        "db:seed": "tsx -r tsconfig-paths/register src/db/seed.ts",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@fastify/cors": "^11.0.1",
        "@fastify/jwt": "^9.1.0",
        "@fastify/schedule": "^6.0.0",
        "@mini-campaign-manager/shared": "*",
        "bcryptjs": "^2.4.3",
        "dotenv": "^16.4.7",
        "fastify": "^5.3.3",
        "ioredis": "^5.10.1",
        "knex": "^3.2.9",
        "pg": "^8.13.1",
        "pino-pretty": "^13.1.3",
        "toad-scheduler": "^3.1.0",
        "tsconfig-paths": "^4.2.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/ioredis": "^4.28.10",
        "@types/node": "^22.10.0",
        "concurrently": "^9.2.1",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.19.2",
        "typescript": "~5.9.2",
        "vitest": "^2.1.8"
    }
}
